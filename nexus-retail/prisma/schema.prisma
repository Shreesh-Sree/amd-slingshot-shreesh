generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  VENDOR
}

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique // Auth mapped from Firebase JWT
  email       String   @unique
  role        Role     @default(USER)
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  eventTags UserEventTag[]
  orders    Order[]
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  inventory   Int      @default(0)
  imageUrl    String?

  // Intelligent Database Caching for Gemini API
  // Static Alt-Text generated once by Gemini via background job
  geminiAltText String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  eventRecommendations EventRecommendation[]
}

// Transient Processed Semantic Tags from Google Calendar
// Represents the parsed "retail intent" (e.g. intent: winter_sports)
model UserEventTag {
  id        String   @id @default(uuid())
  userId    String
  intent    String   // (e.g., 'winter_sports', 'formal_dining')
  environment String? // (e.g., 'cold', 'tropical')
  duration  String? // (e.g., '7_days')
  
  // Cache TTL Logic
  expiresAt DateTime // When the event is over, or cache is stale
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations EventRecommendation[]
}

// Many-to-Many mapping table for caching contextual product recommendations
model EventRecommendation {
  id          String   @id @default(uuid())
  eventTagId  String
  productId   String
  createdAt   DateTime @default(now())

  eventTag UserEventTag @relation(fields: [eventTagId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([eventTagId, productId])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
}

// Stripe integration payload simulation/storage
model Order {
  id             String      @id @default(uuid())
  userId         String
  stripeIntentId String?     @unique
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}
